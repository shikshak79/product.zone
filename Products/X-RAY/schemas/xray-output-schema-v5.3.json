{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "X-RAY Output Schema v5.3",
  "description": "Contract between Hurozo API and Frontend for X-RAY diagnostic reports",
  "type": "object",
  "required": ["meta", "score", "diagnosis", "predictions", "recognition", "risk_signals", "stages", "breakpoint", "decisions", "recommendations", "evidence"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["company", "url", "target_buyer", "date", "version"],
      "properties": {
        "company": { "type": "string", "description": "Company name" },
        "url": { "type": "string", "format": "uri", "description": "Homepage URL scanned" },
        "target_buyer": { "type": "string", "description": "Target buyer role" },
        "date": { "type": "string", "format": "date", "description": "Report date (YYYY-MM-DD)" },
        "version": { "type": "string", "description": "X-RAY version (e.g., '5.3')" }
      }
    },
    "score": {
      "type": "object",
      "required": ["value", "max", "label", "interpretation", "breakdown", "depth"],
      "properties": {
        "value": { "type": "integer", "minimum": 1, "maximum": 10, "description": "Main score (1-10)" },
        "max": { "type": "integer", "const": 10 },
        "label": { 
          "type": "string", 
          "enum": ["Ready to Scale", "Strong", "Solid", "Good", "Proceed with Caution", "Gaps to Address", "Fix Before Outbound", "Major Work Needed", "Broken", "Fundamentally Broken"],
          "description": "Human-readable score label"
        },
        "interpretation": { "type": "string", "description": "One-line interpretation of score" },
        "breakdown": {
          "type": "object",
          "required": ["clear", "partial", "missing"],
          "properties": {
            "clear": { "type": "integer", "minimum": 0, "maximum": 20, "description": "Count of CLEAR questions (out of 20 core)" },
            "partial": { "type": "integer", "minimum": 0, "maximum": 20, "description": "Count of PARTIAL questions" },
            "missing": { "type": "integer", "minimum": 0, "maximum": 20, "description": "Count of MISSING questions" }
          }
        },
        "depth": {
          "type": "object",
          "required": ["status", "q21", "q22"],
          "properties": {
            "status": { "type": "string", "enum": ["Strong", "Partial", "Weak"], "description": "Overall depth content status" },
            "q21": { "type": "string", "enum": ["clear", "partial", "missing"] },
            "q22": { "type": "string", "enum": ["clear", "partial", "missing"] }
          }
        }
      }
    },
    "diagnosis": {
      "type": "object",
      "required": ["verdict", "headline", "text"],
      "properties": {
        "verdict": { 
          "type": "string", 
          "enum": ["Ready for Outbound", "Proceed with Caution", "Fix Before Outbound"],
          "description": "Top-level action verdict"
        },
        "verdict_class": { "type": "string", "enum": ["green", "amber", "red"] },
        "headline": { "type": "string", "description": "One-line diagnostic headline" },
        "text": { "type": "string", "description": "2-3 sentence diagnostic explanation" }
      }
    },
    "predictions": {
      "type": "object",
      "required": ["reply_rate", "demo_conversion", "internal_sell", "pipeline_speed", "summary"],
      "properties": {
        "reply_rate": {
          "type": "object",
          "required": ["value", "basis"],
          "properties": {
            "value": { "type": "string", "enum": ["Strong", "Moderate", "Weak"] },
            "basis": { "type": "string", "description": "Which questions drive this prediction (e.g., 'Based on Q3 + Q6')" }
          }
        },
        "demo_conversion": {
          "type": "object",
          "required": ["value", "basis"],
          "properties": {
            "value": { "type": "string", "enum": ["Strong", "Moderate", "Weak"] },
            "basis": { "type": "string" }
          }
        },
        "internal_sell": {
          "type": "object",
          "required": ["value", "basis"],
          "properties": {
            "value": { "type": "string", "enum": ["Strong", "Moderate", "Weak"] },
            "basis": { "type": "string" }
          }
        },
        "pipeline_speed": {
          "type": "object",
          "required": ["value", "basis"],
          "properties": {
            "value": { "type": "string", "enum": ["Strong", "Moderate", "Slow"] },
            "basis": { "type": "string" }
          }
        },
        "summary": { "type": "string", "description": "One-sentence prediction summary" }
      }
    },
    "recognition": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "type": "string" },
      "description": "4 expected objections/questions from sales calls"
    },
    "risk_signals": {
      "type": "object",
      "required": ["message_priority", "buyer_focus", "why_act_now", "proof_relevance", "explanation_burden", "internal_sharing", "mixed_signals"],
      "properties": {
        "message_priority": {
          "type": "object",
          "required": ["value", "basis", "evidence"],
          "properties": {
            "value": { "type": "string", "enum": ["Strong", "Weak", "High Risk"] },
            "basis": { "type": "string", "description": "Which questions compose this signal (e.g., 'Q3, Q4, Q5')" },
            "evidence": { "type": "string", "description": "One-sentence evidence explanation" }
          }
        },
        "buyer_focus": {
          "type": "object",
          "required": ["value", "basis", "evidence"],
          "properties": {
            "value": { "type": "string", "enum": ["Strong", "Weak", "High Risk"] },
            "basis": { "type": "string" },
            "evidence": { "type": "string" }
          }
        },
        "why_act_now": {
          "type": "object",
          "required": ["value", "basis", "evidence"],
          "properties": {
            "value": { "type": "string", "enum": ["Strong", "Weak", "High Risk"] },
            "basis": { "type": "string" },
            "evidence": { "type": "string" }
          }
        },
        "proof_relevance": {
          "type": "object",
          "required": ["value", "basis", "evidence"],
          "properties": {
            "value": { "type": "string", "enum": ["Strong", "Weak", "High Risk"] },
            "basis": { "type": "string" },
            "evidence": { "type": "string" }
          }
        },
        "explanation_burden": {
          "type": "object",
          "required": ["value", "basis", "evidence"],
          "properties": {
            "value": { "type": "string", "enum": ["Strong", "Weak", "High Risk"] },
            "basis": { "type": "string" },
            "evidence": { "type": "string" }
          }
        },
        "internal_sharing": {
          "type": "object",
          "required": ["value", "basis", "evidence"],
          "properties": {
            "value": { "type": "string", "enum": ["Strong", "Weak", "High Risk"] },
            "basis": { "type": "string" },
            "evidence": { "type": "string" }
          }
        },
        "mixed_signals": {
          "type": "object",
          "required": ["value", "basis", "evidence"],
          "properties": {
            "value": { "type": "string", "enum": ["Strong", "Weak", "High Risk"] },
            "basis": { "type": "string" },
            "evidence": { "type": "string" }
          }
        }
      }
    },
    "stages": {
      "type": "object",
      "required": ["land", "make_sense", "self_select", "compare", "validate", "commit"],
      "properties": {
        "land": { "type": "string", "enum": ["ok", "weak", "break"] },
        "make_sense": { "type": "string", "enum": ["ok", "weak", "break"] },
        "self_select": { "type": "string", "enum": ["ok", "weak", "break"] },
        "compare": { "type": "string", "enum": ["ok", "weak", "break"] },
        "validate": { "type": "string", "enum": ["ok", "weak", "break"] },
        "commit": { "type": "string", "enum": ["ok", "weak", "break"] }
      }
    },
    "breakpoint": {
      "type": "object",
      "required": ["stage", "insight", "missing_items"],
      "properties": {
        "stage": { "type": "string", "enum": ["land", "make_sense", "self_select", "compare", "validate", "commit", "none"], "description": "Primary breakpoint stage, or 'none' if no breaks" },
        "stage_class": { "type": "string", "enum": ["red", "amber", "green"] },
        "insight": { "type": "string", "description": "2-3 sentences explaining the breakpoint" },
        "missing_items": {
          "type": "array",
          "items": { 
            "type": "object",
            "required": ["text", "status"],
            "properties": {
              "text": { "type": "string" },
              "status": { "type": "string", "enum": ["missing", "partial"] }
            }
          },
          "description": "List of things buyers cannot find"
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "finding"],
        "properties": {
          "name": { "type": "string", "description": "Decision name (e.g., 'Category', 'Alternative')" },
          "status": { "type": "string", "enum": ["clear", "partial", "missing"] },
          "status_label": { "type": "string", "enum": ["Clear", "Unclear", "Implicit", "Weak", "Missing", "Scattered"] },
          "finding": { "type": "string", "description": "One-sentence finding" }
        }
      },
      "description": "3-4 key decision gaps"
    },
    "recommendations": {
      "type": "object",
      "required": ["eyebrow", "action", "goals"],
      "properties": {
        "eyebrow": { "type": "string", "description": "Recommendation framing (e.g., 'Light Refinement', 'Recommended Path')" },
        "action": { "type": "string", "description": "Main action headline" },
        "goals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "description"],
            "properties": {
              "label": { "type": "string", "description": "Bold label (e.g., 'Define Category')" },
              "description": { "type": "string", "description": "Explanation of action" }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 22,
      "maxItems": 22,
      "items": {
        "type": "object",
        "required": ["id", "stage", "question", "quote", "inference", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^Q[0-9]{1,2}$", "description": "Question ID (Q1-Q22)" },
          "stage": { "type": "string", "enum": ["land", "make_sense", "self_select", "compare", "validate", "commit", "depth"] },
          "question": { "type": "string", "description": "Short question text" },
          "quote": { "type": "string", "description": "Evidence quote from homepage (or 'Not found')" },
          "inference": { "type": "string", "description": "What the evidence means" },
          "status": { "type": "string", "enum": ["clear", "partial", "missing"] }
        }
      }
    },
    "indicators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["what", "direction"],
        "properties": {
          "what": { "type": "string", "description": "What to track" },
          "direction": { "type": "string", "description": "Expected direction after fix" }
        }
      },
      "description": "Progress indicators to track (optional)"
    }
  }
}
